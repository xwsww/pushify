# Production configuration
# Copy to /var/lib/devpush/.env and fill in your values

# Secrets (auto-generated by install.sh)
SECRET_KEY=
ENCRYPTION_KEY= # python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
POSTGRES_PASSWORD=
MARIADB_ROOT_PASSWORD=

# System (auto-generated by install.sh)
SERVICE_UID=
SERVICE_GID=
SERVER_IP= # Public IP of the server

# Domains & SSL
APP_HOSTNAME=example.com
DEPLOY_DOMAIN=example.com
LE_EMAIL=admin@example.com
# default|cloudflare|route53|gcloud|digitalocean|azure
CERT_CHALLENGE_PROVIDER=default
# Panel: 1 = HTTPS on :443 (default), 0 = HTTP on :80 only (e.g. before Let's Encrypt rate limit clears)
# DEVPUSH_ENABLE_HTTPS=1
# CF_DNS_API_TOKEN=

# GitHub App (see https://github.com/xwsww/pushify#quickstart)
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_PRIVATE_KEY= # PEM content, use \n for newlines
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Optional
# GITHUB_REPO_TOKEN= # Required for private repo version checks and panel updates
# REGISTRY_CATALOG_URL=https://raw.githubusercontent.com/xwsww/pushify/refs/heads/main/registry/catalog.json
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MARIADB_HOST=mariadb
# MARIADB_PORT=3306
# MARIADB_ROOT_USER=root
# PHPMYADMIN_HOSTNAME=db.panel.example.com
# APP_NAME=/pushify/
# APP_DESCRIPTION=
# POSTGRES_DB=devpush
# POSTGRES_USER=devpush-app
# REDIS_URL=redis://redis:6379
# Deployment resources (install.sh and start.sh auto-detect from server RAM/CPU)
# DEFAULT_CPUS=
# MAX_CPUS=
# DEFAULT_MEMORY_MB=
# MAX_MEMORY_MB=
# RUNNER_FALLBACK_CPUS=
# RUNNER_FALLBACK_MEMORY_MB=
# RUNNER_OOM_SCORE_ADJ=500
# DOCKER_TRANSIENT_FAILURE_THRESHOLD=15
# DEFAULT_DB_SIZE_LIMIT_BYTES=5368709120
# JOB_TIMEOUT_SECONDS=320
# JOB_MAX_TRIES=3
# DEPLOYMENT_TIMEOUT_SECONDS=300
# MAGIC_LINK_TTL_SECONDS=900
# AUTH_TOKEN_TTL_DAYS=30
# AUTH_TOKEN_REFRESH_THRESHOLD_DAYS=1
# AUTH_TOKEN_ISSUER=devpush-app
# AUTH_TOKEN_AUDIENCE=devpush-web
# LOG_LEVEL=WARNING
# UVICORN_WORKERS=2
# DEVPUSH_COMPOSE_PROFILES=optional
