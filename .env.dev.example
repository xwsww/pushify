# Local development configuration
# Copy to ./data/.env and fill in your values

# Secrets
SECRET_KEY=
ENCRYPTION_KEY= # python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
POSTGRES_PASSWORD=pgsql_password

# Domains & SSL
APP_HOSTNAME=localhost
DEPLOY_DOMAIN=localhost
SERVER_IP=127.0.0.1
LE_EMAIL=dev@example.com

# GitHub App (see https://github.com/xwsww/pushify#quickstart)
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_PRIVATE_KEY= # PEM content, use \n for newlines
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Optional
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APP_NAME=/pushify/
# APP_DESCRIPTION=
# EMAIL_SENDER_NAME=/pushify/
# POSTGRES_DB=devpush
# POSTGRES_USER=devpush-app
# REDIS_URL=redis://redis:6379
# Filled automatically on first ./scripts/start.sh from host RAM/CPU
# DEFAULT_CPUS=
# MAX_CPUS=
# DEFAULT_MEMORY_MB=
# MAX_MEMORY_MB=
# DEFAULT_DB_SIZE_LIMIT_BYTES=5368709120
# JOB_TIMEOUT_SECONDS=320
# JOB_MAX_TRIES=3
# DEPLOYMENT_TIMEOUT_SECONDS=300
# MAGIC_LINK_TTL_SECONDS=900
# AUTH_TOKEN_TTL_DAYS=30
# AUTH_TOKEN_REFRESH_THRESHOLD_DAYS=1
# AUTH_TOKEN_ISSUER=devpush-app
# AUTH_TOKEN_AUDIENCE=devpush-web
# LOG_LEVEL=WARNING
# DEVPUSH_ENABLE_HTTPS=1
# Production host hardening (install.sh sets these on prod)
# DEVPUSH_ENABLE_CROWDSEC=1
# DEVPUSH_ORIGIN_SHIELD=1
# DEVPUSH_UFW=1
# DEVPUSH_SSH_ALLOW_CIDR=203.0.113.10/32
# DEVPUSH_TRUSTED_PROXY_CIDRS=81.28.12.12/32
